apiVersion: helm.cattle.io/v1
kind: HelmChart
metadata:
  name: reloader
  namespace: kube-system
spec:
  targetNamespace: {{ reloader.namespace }}
  createNamespace: true
  chart: reloader
  repo: https://stakater.github.io/stakater-charts
  version: {{ reloader.chart_version }}
  timeout: 10m
  valuesContent: |-
    reloader:
      watchGlobally: {{ reloader.watch_globally | lower }}
      enableHA: {{ (reloader.deployment.replicas | int > 1) | lower }}
      reloadStrategy: {{ reloader.reload_strategy }}
      deployment:
        replicas: {{ reloader.deployment.replicas }}
        priorityClassName: {{ reloader.priority_class_name }}
        resources:
          requests:
            cpu: {{ reloader.deployment.resources.requests.cpu }}
            memory: {{ reloader.deployment.resources.requests.memory }}
          limits:
            memory: {{ reloader.deployment.resources.limits.memory }}
        affinity:
          podAntiAffinity:
            requiredDuringSchedulingIgnoredDuringExecution:
              - labelSelector:
                  matchLabels:
                    app.kubernetes.io/instance: reloader
                    app.kubernetes.io/name: reloader
                topologyKey: kubernetes.io/hostname
        topologySpreadConstraints:
          - maxSkew: 1
            topologyKey: kubernetes.io/hostname
            whenUnsatisfiable: DoNotSchedule
            labelSelector:
              matchLabels:
                app.kubernetes.io/instance: reloader
                app.kubernetes.io/name: reloader
      podDisruptionBudget:
        enabled: true
        minAvailable: {{ reloader.pod_disruption_budget.min_available }}
